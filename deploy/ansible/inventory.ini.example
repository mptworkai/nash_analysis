# ── Inventory ──────────────────────────────────────────────────────────────
# Copy this file to inventory.ini and fill in your server details.
# inventory.ini is gitignored — never commit it.
#
# ansible_user must have passwordless sudo (or you'll be prompted).
#
# Examples:
#   192.168.1.100 ansible_user=ubuntu
#   myserver.example.com ansible_user=mike
#   myserver.example.com ansible_user=mike ansible_port=2222
#   myserver.example.com ansible_user=mike ansible_ssh_private_key_file=~/.ssh/mykey

[nash_events]
your-server-ip-or-hostname ansible_user=your_username

[nash_events:vars]
# ansible_ssh_private_key_file=~/.ssh/id_rsa
# ansible_port=22
