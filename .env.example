# Copy to .env and fill in:
#
#   cp .env.example .env
#
# Then generate values:
#
#   python make_password.py            → outputs b64:<hash> — paste that below
#   python -c "import secrets; print(secrets.token_urlsafe(48))"  → SECRET_KEY
#
# NASH_PASSWORD_HASH uses a "b64:" prefix (base64-encoded bcrypt hash).
# This avoids docker-compose misinterpreting the $ signs in raw bcrypt hashes.

NASH_USERNAME=admin
NASH_PASSWORD_HASH=
SECRET_KEY=

# Optional — change the port the container is published on.
# HOST_PORT=5050
